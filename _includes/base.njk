<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% set isPost = page.url | isPostUrl %}
    {% set pageDescription = description or excerpt or metadata.description %}
    {% set canonicalUrl = metadata.url + page.url %}
    {% set socialImage = metadata.url + (image or metadata.image) %}

    <title>{{ title }} | {{ metadata.title }}</title>
    <meta name="description" content="{{ pageDescription }}">
    <meta name="author" content="{{ metadata.author.name }}">
    <link rel="canonical" href="{{ canonicalUrl }}">

    <!-- Open Graph -->
    <meta property="og:site_name" content="{{ metadata.title }}">
    <meta property="og:title" content="{{ title }} | {{ metadata.title }}">
    <meta property="og:description" content="{{ pageDescription }}">
    <meta property="og:type" content="{{ 'article' if isPost else 'website' }}">
    <meta property="og:url" content="{{ canonicalUrl }}">
    <meta property="og:image" content="{{ socialImage }}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="{{ metadata.title }}">
    {%- if isPost %}
    <meta property="article:published_time" content="{{ page.date | rfc3339 }}">
    <meta property="article:author" content="{{ metadata.author.name }}">
    {%- endif %}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="{{ canonicalUrl }}">
    <meta name="twitter:title" content="{{ title }} | {{ metadata.title }}">
    <meta name="twitter:description" content="{{ pageDescription }}">
    <meta name="twitter:image" content="{{ socialImage }}">

    <!-- Feed autodiscovery -->
    <link rel="alternate" type="application/atom+xml" title="{{ metadata.title }}" href="{{ metadata.url }}{{ metadata.feedPath }}">

    <!-- Structured data -->
    <script type="application/ld+json">
    {%- if isPost %}
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": {{ title | dump | safe }},
      "description": {{ pageDescription | dump | safe }},
      "datePublished": {{ page.date | rfc3339 | dump | safe }},
      "dateModified": {{ page.date | rfc3339 | dump | safe }},
      "url": {{ canonicalUrl | dump | safe }},
      "mainEntityOfPage": { "@type": "WebPage", "@id": {{ canonicalUrl | dump | safe }} },
      "image": {{ socialImage | dump | safe }},
      "author": { "@type": "Person", "name": {{ metadata.author.name | dump | safe }}, "url": {{ metadata.author.url | dump | safe }} },
      "publisher": { "@type": "Person", "name": {{ metadata.author.name | dump | safe }} }
    }
    {%- else %}
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": {{ metadata.title | dump | safe }},
      "description": {{ metadata.description | dump | safe }},
      "url": {{ metadata.url | dump | safe }},
      "author": { "@type": "Person", "name": {{ metadata.author.name | dump | safe }}, "url": {{ metadata.author.url | dump | safe }} }
    }
    {%- endif %}
    </script>

    <!-- Set the theme before first paint to avoid a flash -->
    <script>
        (function () {
            var t = localStorage.getItem('theme');
            if (t) document.documentElement.setAttribute('data-theme', t);
        })();
    </script>

    <!-- Prism: code blocks are always dark terminals, in both themes -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css">

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@400;700&display=swap');

        :root {
            --width: 720px;
            --font-main: 'Roboto Mono', monospace;
            --font-secondary: 'Roboto Mono', monospace;
            --font-scale: .9em;
            --background-color: #fff;
            --heading-color: #232333;
            --text-color: #232333;
            --link-color: #232333;
            --main-color: #0011ffff;
            --border-color: #232333;
            --muted-color: #555;
        }

        /* Dark theme colors */
        [data-theme="dark"] {
            --background-color: #1a1a1a;
            --heading-color: #e0e0e0;
            --text-color: #d0d0d0;
            --link-color: #e0e0e0;
            --main-color: #5588ff;
            --border-color: #e0e0e0;
            --muted-color: #999;
        }

        /* Auto dark mode based on system preference */
        @media (prefers-color-scheme: dark) {
            :root:not([data-theme="light"]) {
                --background-color: #1a1a1a;
                --heading-color: #e0e0e0;
                --text-color: #d0d0d0;
                --link-color: #e0e0e0;
                --main-color: #5588ff;
                --border-color: #e0e0e0;
                --muted-color: #999;
            }
        }

        body {
            font-family: var(--font-secondary);
            font-size: var(--font-scale);
            margin: auto;
            padding: 20px;
            max-width: var(--width);
            background-color: var(--background-color);
            line-height: 1.6;
            color: var(--text-color);
            transition: background-color 0.3s ease, color 0.3s ease;
        }
        h1,h2,h3,h4,h5,h6 { font-family: var(--font-main); color: var(--heading-color); }
        a { color: var(--link-color); text-decoration: none; border-bottom: 3px solid var(--main-color); padding-bottom: 2px; }
        a:hover { background-color: var(--main-color); color: white; }
        header { margin-bottom: 40px; padding-bottom: 20px; border-bottom: 3px dotted var(--border-color); }
        footer { margin-top: 40px; border-top: 3px dotted var(--border-color); padding: 25px 0; text-align: center; color: var(--muted-color); font-size: 0.9em; }
        footer a { color: var(--muted-color); border-bottom: 1px solid var(--main-color); padding-bottom: 1px; }
        footer a:hover { background-color: var(--main-color); color: white; }
        footer .ssh-hint { color: var(--muted-color); cursor: help; }

        /* Theme toggle link */
        .theme-toggle {
            background: none;
            border: none;
            font-family: var(--font-secondary);
            font-size: inherit;
            cursor: pointer;
            padding: 0;
            color: var(--link-color);
            border-bottom: 3px solid var(--main-color);
            padding-bottom: 2px;
        }
        .theme-toggle:hover {
            background-color: var(--main-color);
            color: white;
        }
        main h1:first-child, main h2:first-child { margin-top: 0; }
        /* A little style so the main h1 doesn't have an underline from the header link */
        header a { border-bottom: none; }

        /* ---- POST LIST ---- */
.post-list {
    list-style-type: none;
    padding: 0;
    margin: 0;
}
.post-entry {
    padding: 1.6em 0;
    border-bottom: 1px dotted var(--muted-color);
}
.post-entry:last-child {
    border-bottom: none;
}
.post-title {
    font-size: 1.3em;
    font-weight: bold;
    line-height: 1.4;
    border-bottom: none; /* the whole title is the link; no underline */
}
.post-title:hover {
    background-color: inherit;
    color: var(--main-color);
}
.post-meta {
    color: var(--muted-color);
    font-size: 0.85em;
    margin: 0 0 0.35em 0;
}
.post-excerpt {
    color: var(--muted-color);
    margin: 0.6em 0 0;
}

/* ---- UTILITY CLASSES FOR LINKS ---- */
.no-underline a {
    border-bottom: none; /* Removes the blue underline */
}

.no-underline a:hover {
    background-color: inherit; /* Disables the red background on hover */
    color: var(--main-color); /* Changes text to blue on hover */
}

/* Clean list styling */
.clean-list {
    list-style-type: none;
    padding: 0;
    margin: 0;
}

.clean-list li {
    margin-bottom: 1em;
}

/* Bold links */
.bold-links a {
    font-weight: bold;
}

/* Muted text for dates/meta */
.muted {
    color: var(--muted-color);
    font-size: 0.9em;
}

/* Combined utility class for recent posts */
.recent-posts {
    list-style-type: none;
    padding: 0;
    margin: 0;
}

.recent-posts li {
    margin-bottom: 1em;
}

.recent-posts a {
    border-bottom: none;
    font-weight: bold;
}

.recent-posts a:hover {
    background-color: inherit;
    color: var(--main-color);
}

        .recent-posts time {
            color: var(--muted-color);
            font-size: 0.9em;
            margin-left: 0.5em;
        }

        /* Code blocks: always dark terminal panels, in both themes */
        pre,
        pre[class*="language-"] {
            background-color: #14151d;
            color: #d8dae4;
            border: 1px solid #2a2c3a;
            border-radius: 8px;
            padding: 1em 1.25em;
            overflow-x: auto;
            margin: 1.5em 0;
            line-height: 1.6;
        }

        code {
            font-family: 'Roboto Mono', monospace;
            font-size: 0.9em;
        }

        pre code {
            display: block;
            background: transparent;
            padding: 0;
        }

        /* Inline code */
        :not(pre) > code {
            background-color: rgba(0, 17, 255, 0.1);
            padding: 0.2em 0.4em;
            border-radius: 3px;
            font-size: 0.9em;
        }

        [data-theme="dark"] :not(pre) > code {
            background-color: rgba(85, 136, 255, 0.2);
        }

        /* Mermaid diagram styling */
        .mermaid {
            background-color: var(--background-color);
            border: 1px solid var(--border-color);
            border-radius: 4px;
            padding: 1.5em;
            margin: 1.5em 0;
            text-align: center;
            overflow-x: auto;
        }
    </style>
</head>
<body>
    <header>
        <a href="/"><h1>Tate McCauley</h1></a>
        <nav>
            <a href="/">Home</a>
            <a href="/posts/">Blog</a>
            <a href="/about/">About</a>
            <a href="/resume/">Resume</a>
            <a href="/now/">Now</a>
            <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode">
                <span id="theme-text">Dark</span>
            </button>
        </nav>
    </header>

    <main>
        {{ content | safe }}
    </main>

    <footer>
        <span>&copy; {% year %} Tate McCauley · <a href="{{ metadata.feedPath }}">rss</a> · <a href="https://www.linkedin.com/in/tate-mccauley/">linkedin</a> · <a href="https://github.com/21tmccauley">github</a> · <span class="ssh-hint" title="This blog also runs over SSH — same posts, no browser">ssh tatemccauley.com</span></span>
    </footer>

    <script>
        // Theme toggle functionality
        const html = document.documentElement;
        const themeToggle = document.getElementById('theme-toggle');
        const themeText = document.getElementById('theme-text');

        // Check for saved theme preference or default to system preference
        const currentTheme = localStorage.getItem('theme');

        if (currentTheme) {
            html.setAttribute('data-theme', currentTheme);
            updateText(currentTheme);
        } else {
            // Check system preference
            const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            if (prefersDark) {
                updateText('dark');
            }
        }

        // Toggle theme
        themeToggle.addEventListener('click', () => {
            const currentTheme = html.getAttribute('data-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';

            html.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            updateText(newTheme);
        });

        // Update text based on theme
        function updateText(theme) {
            if (theme === 'dark') {
                themeText.textContent = 'Light';
            } else {
                themeText.textContent = 'Dark';
            }
        }

        // Listen for system theme changes
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
            if (!localStorage.getItem('theme')) {
                const newTheme = e.matches ? 'dark' : 'light';
                updateText(newTheme);
            }
        });
    </script>

    <!-- Prism.js for syntax highlighting -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-core.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/plugins/autoloader/prism-autoloader.min.js"></script>

    <!-- Mermaid.js for diagrams -->
    <script type="module">
        import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs';

        function isDark() {
            const explicit = document.documentElement.getAttribute('data-theme');
            return explicit ? explicit === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
        }

        // themeVariables only take effect with the 'base' theme
        function getThemeVariables(dark) {
            return dark ? {
                fontFamily: 'Roboto Mono, monospace',
                primaryColor: '#252c3f',
                primaryTextColor: '#e0e0e0',
                primaryBorderColor: '#5588ff',
                lineColor: '#999999',
                secondaryColor: '#2a2a2a',
                tertiaryColor: '#1a1a1a'
            } : {
                fontFamily: 'Roboto Mono, monospace',
                primaryColor: '#e9ebff',
                primaryTextColor: '#232333',
                primaryBorderColor: '#0011ff',
                lineColor: '#555555',
                secondaryColor: '#f0f0f0',
                tertiaryColor: '#ffffff'
            };
        }

        function initializeMermaid() {
            mermaid.initialize({
                startOnLoad: false,
                theme: 'base',
                themeVariables: getThemeVariables(isDark())
            });

            // Convert code blocks with language-mermaid to div.mermaid
            document.querySelectorAll('code.language-mermaid').forEach(codeEl => {
                const pre = codeEl.parentElement;
                const mermaidDiv = document.createElement('div');
                mermaidDiv.className = 'mermaid';
                mermaidDiv.textContent = codeEl.textContent;
                pre.parentNode.replaceChild(mermaidDiv, pre);
            });

            // Render all Mermaid diagrams
            document.querySelectorAll('.mermaid').forEach(async (el) => {
                if (!el.hasAttribute('data-processed')) {
                    el.setAttribute('data-processed', 'true');
                    const id = 'mermaid-' + Math.random().toString(36).substr(2, 9);
                    const definition = el.textContent.trim();
                    try {
                        const { svg } = await mermaid.render(id, definition);
                        el.innerHTML = svg;
                        el.setAttribute('data-definition', definition);
                    } catch (error) {
                        console.error('Mermaid rendering error:', error);
                        el.innerHTML = '<p>Diagram failed to render — view the source of this page for its definition.</p>';
                    }
                }
            });
        }

        // Initialize on page load
        initializeMermaid();

        // Update Mermaid theme when user toggles dark mode
        const observer = new MutationObserver(() => {
            mermaid.initialize({
                startOnLoad: false,
                theme: 'base',
                themeVariables: getThemeVariables(isDark())
            });

            // Re-render all Mermaid diagrams with new theme
            document.querySelectorAll('.mermaid[data-processed]').forEach(async (el) => {
                const id = 'mermaid-' + Math.random().toString(36).substr(2, 9);
                const definition = el.getAttribute('data-definition') || el.textContent.trim();
                try {
                    const { svg } = await mermaid.render(id, definition);
                    el.innerHTML = svg;
                } catch (error) {
                    console.error('Mermaid rendering error:', error);
                }
            });
        });

        observer.observe(document.documentElement, {
            attributes: true,
            attributeFilter: ['data-theme']
        });
    </script>
</body>
</html>
